# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Test coverage
coverage/

# Hook-generated reports (root-level only — must NOT match the web source dir
# apps/web/src/pages/reports/, which is real application code)
/reports/

# Local Claude Code settings (personal, machine-specific overrides)
.claude/settings.local.json

# OS / editor cruft
.DS_Store
Thumbs.db

# core/db/types.generated.ts is COMMITTED (so worktrees/CI get typed DB access
# without a live database); regenerate with `npm run db:codegen` after schema changes.

# Test / build artefacts
playwright-report/
test-results/
.vite/
