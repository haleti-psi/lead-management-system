# Authoritative list: docs/contracts/environment-contract.md
# Copy to .env.local for local dev. Secrets in prod come from Secret Manager.

NODE_ENV=development
PORT=8080

# --- Database (local Postgres 15, or Cloud SQL Auth Proxy) ---
DATABASE_URL=postgresql://app:app@localhost:5432/lms_dev

# --- Auth (dev secrets; generate real ones: openssl rand -base64 32) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# --- Redis (cache, rate-limit, idempotency) ---
REDIS_URL=redis://localhost:6379

# --- GCP (dev: stubs/emulators) ---
GCP_PROJECT=lms-dev
GCP_REGION=asia-south1
GCS_BUCKET=lms-dev-docs
PUBSUB_TOPIC_EVENTS=lms-domain-events
CLOUD_TASKS_QUEUE=lms-integration
CLOUD_TASKS_LOCATION=asia-south1

# --- CORS / customer links ---
ALLOWED_ORIGINS=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# --- PII tokenisation (dev placeholder) ---
TOKENIZATION_KMS_KEY=dev-local-key

# --- Integrations (dev: mock adapters) ---
LOS_MOCK=true

# --- Operational windows (FR-003 / FR-021) ---
BREAK_GLASS_MAX_WINDOW_HOURS=48
MERGE_UNMERGE_WINDOW_HOURS=24

# --- Web (Vite build-time) ---
VITE_API_BASE_URL=http://localhost:8080
